{
  "name": "browser-agent-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && vite build --config vite.content.config.ts && vite build --config vite.webmcp.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "test:e2e:debug": "npm run build && PWDEBUG=1 playwright test"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "dompurify": "^3.4.9",
    "fflate": "^0.8.3",
    "marked": "^18.0.5",
    "pdfjs-dist": "^6.0.227",
    "preact": "^10.24.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@preact/preset-vite": "^2.9.1",
    "@types/chrome": "^0.0.287",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^4.1.8"
  }
}
