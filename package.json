{
  "name": "browser-agent-extension",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && vite build --config vite.content.config.ts && vite build --config vite.webmcp.config.ts && vite build --config vite.pointer.config.ts && vite build --config vite.learn.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "test:e2e:debug": "npm run build && PWDEBUG=1 playwright test",
    "addin:typecheck": "tsc --noEmit -p word-addin/tsconfig.json",
    "addin:build": "vite build --config word-addin/vite.config.ts",
    "addin:dev": "vite --config word-addin/vite.config.ts",
    "addin:certs": "office-addin-dev-certs install",
    "addin:sideload": "office-addin-debugging start word-addin/manifest.xml",
    "addin:stop": "office-addin-debugging stop word-addin/manifest.xml",
    "addin:proxy": "node word-addin/proxy.mjs",
    "demo:record": "npm run build && node scripts/demo/record.ts",
    "demo:setup": "uv venv scripts/demo/.venv --python 3.12 && uv pip install --python scripts/demo/.venv/bin/python mlx-audio \"misaki[en]\" espeakng-loader phonemizer-fork https://github.com/explosion/spacy-models/releases/download/en_core_web_sm-3.8.0/en_core_web_sm-3.8.0-py3-none-any.whl"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "docx": "^9.7.1",
    "dompurify": "^3.4.9",
    "fflate": "^0.8.3",
    "marked": "^18.0.5",
    "pdfjs-dist": "^6.0.227",
    "pptxgenjs": "^3.12.0",
    "preact": "^10.24.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@preact/preset-vite": "^2.9.1",
    "@types/chrome": "^0.0.287",
    "@types/office-js": "^1.0.592",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "office-addin-debugging": "^6.1.1",
    "office-addin-dev-certs": "^2.0.9",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^4.1.8"
  }
}
